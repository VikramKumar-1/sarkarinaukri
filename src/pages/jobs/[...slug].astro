---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const jobEntries = await getCollection('jobs');
  return jobEntries.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const { 
  title, shortInfo, 
  departmentName, postTitleName, advtNoShortDetails,
  importantDates, applicationFee, 
  ageLimitTitle, ageLimitDetails,
  vacancyTableTitle, vacancyDetails, districtVacancyTitle, districtVacancyDetails, categoryVacancyDetails, physicalEligibility, 
  howToFillTitle, howToFillDetails,
  importantLinks, faq,
  seoTitle, seoDescription, seoKeywords 
} = entry.data;

// Automatically capture postDate
const postDate = entry.data.postDate || new Date().toISOString();

// Format the date to look like Sarkari Result: "22 June 2026 | 10:15 PM"
const formattedDate = new Date(postDate).toLocaleString('en-IN', {
  day: '2-digit',
  month: 'long',
  year: 'numeric',
  hour: '2-digit',
  minute: '2-digit',
  hour12: true,
  timeZone: 'Asia/Kolkata'
}).replace(',', ' |');

const finalTitle = seoTitle || `${title} | Sarkari Result`;
const finalDesc = seoDescription || shortInfo;
const finalKeywords = seoKeywords || `sarkari result, ${title}, online form, latest jobs`;

// Auto-Generated Unique SEO FAQs (If user leaves FAQ blank in Admin)
const autoFaq = [
  {
    question: `What is the last date to apply for ${title}?`,
    answer: `The last date to apply online for the ${title} recruitment is strictly mentioned in the important dates section above. Candidates are advised to submit their online applications well before the final deadline to avoid any last-minute server issues.`
  },
  {
    question: `How can I download the ${title} Official Notification PDF?`,
    answer: `You can easily download the official notification PDF by scrolling down to the 'Important Links' section at the bottom of this page and clicking on the direct 'Download Notification' link.`
  },
  {
    question: `What is the age limit and eligibility for this recruitment?`,
    answer: `The complete age limit criteria and educational eligibility details are clearly provided in the respective sections above. Extra age relaxation is also applicable as per the official recruitment rules.`
  },
  {
    question: `Where is the direct link to apply online for ${title}?`,
    answer: `Eligible and interested candidates can apply online directly through the official website. For your convenience, we have provided the direct 'Apply Online' link in the Important Links section below.`
  }
];

const displayFaq = (faq && faq.length > 0) ? faq : autoFaq;

// Google JobPosting Schema
const jobSchemaObj = {
  "@context": "https://schema.org/",
  "@type": "JobPosting",
  "title": title,
  "description": finalDesc,
  "datePosted": postDate,
  "validThrough": new Date(new Date().getTime() + 30*24*60*60*1000).toISOString(),
  "employmentType": "FULL_TIME",
  "hiringOrganization": {
    "@type": "Organization",
    "name": departmentName || "Government of India",
    "sameAs": "https://www.sarkariresult.com"
  },
  "jobLocation": {
    "@type": "Place",
    "address": {
      "@type": "PostalAddress",
      "addressCountry": "IN"
    }
  }
};
const jobSchema = JSON.stringify(jobSchemaObj);

// Google FAQPage Schema
const faqSchemaObj = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": displayFaq.map(f => ({
    "@type": "Question",
    "name": f.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": f.answer
    }
  }))
};
const faqSchema = JSON.stringify(faqSchemaObj);
---

<Layout 
  title={finalTitle}
  description={finalDesc}
  keywords={finalKeywords}
  jobSchema={jobSchema}
  faqSchema={faqSchema}
>
	<article class="job-detail-container">
		
		<!-- SEO Info Box (Top) -->
		<div class="post-header-box">
			<h1 class="post-title"><span class="label">Name of Post:</span> {title}</h1>
			<p class="post-date"><span class="label">Post Date / Update:</span> {formattedDate}</p>
			<p class="post-info"><span class="label">Short Information:</span> {shortInfo}</p>
		</div>

		<!-- EXACT SARKARI RESULT MASTER TABLE -->
		<table class="sarkari-master-table">
			<!-- SECTION 1: HEADERS -->
			<tr>
				<td colspan={2} style="padding: 15px; text-align: center;">
					{departmentName && <h2 style="color: #ff00ff; font-size: 24px; margin-bottom: 10px; margin-top: 0;">{departmentName}</h2>}
					{postTitleName && <h3 style="color: #008000; font-size: 22px; margin-bottom: 10px; margin-top: 0;">{postTitleName}</h3>}
					{advtNoShortDetails && <h4 style="color: #ff00ff; font-size: 20px; margin-bottom: 15px; margin-top: 0;">{advtNoShortDetails}</h4>}
					<div style="color: #ff0000; font-size: 24px; font-weight: bold;">Sarkari Result® WWW.SARKARIRESULT.COM Since 2012</div>
				</td>
			</tr>

			<!-- SECTION 2: DATES & FEES -->
			<tr>
				<td style="width: 50%; vertical-align: top; padding: 15px; border-right: 1px solid #000;">
					<h2 style="text-align: center; color: #008000; font-size: 24px; margin-bottom: 15px; margin-top: 0;">Important Dates</h2>
					<ul style="margin-left: 20px;">
						{importantDates && importantDates.split('\n').map(date => date.trim() ? <li style="font-size: 18px; margin-bottom: 8px;">{date}</li> : null)}
					</ul>
				</td>
				<td style="width: 50%; vertical-align: top; padding: 15px;">
					<h2 style="text-align: center; color: #008000; font-size: 24px; margin-bottom: 15px; margin-top: 0;">Application Fees</h2>
					<ul style="margin-left: 20px;">
						{applicationFee && applicationFee.split('\n').map(fee => fee.trim() ? <li style="font-size: 18px; margin-bottom: 8px;">{fee}</li> : null)}
					</ul>
				</td>
			</tr>

			<!-- SECTION 3: AGE LIMIT -->
			{(ageLimitTitle || ageLimitDetails) && (
				<tr>
					<td colspan={2} style="padding: 15px;">
						{ageLimitTitle && <h2 style="text-align: center; font-size: 24px; margin-bottom: 15px; color: #ff00ff; margin-top: 0;">{ageLimitTitle}</h2>}
						<ul style="margin-left: 20px;">
							{ageLimitDetails && ageLimitDetails.split('\n').map(item => item.trim() ? <li style="font-size: 18px; margin-bottom: 8px;">{item}</li> : null)}
						</ul>
					</td>
				</tr>
			)}

			<!-- SECTION 4: VACANCY DETAILS -->
			{(vacancyTableTitle || (vacancyDetails && vacancyDetails.length > 0) || (categoryVacancyDetails && categoryVacancyDetails.length > 0) || (physicalEligibility && physicalEligibility.length > 0)) && (
				<tr>
					<td colspan={2} style="padding: 15px;">
						{vacancyTableTitle && <h2 style="text-align: center; font-size: 24px; margin-bottom: 15px; color: #ff00ff; margin-top: 0;">{vacancyTableTitle}</h2>}
						
						{vacancyDetails && vacancyDetails.length > 0 && (
							<table class="inner-table">
								<thead>
									<tr>
										<th>Post Name</th>
										<th>Total Post</th>
										<th>Eligibility Details</th>
									</tr>
								</thead>
								<tbody>
									{vacancyDetails.map(vacancy => (
										<tr>
											<td>{vacancy.postName}</td>
											<td>{vacancy.totalPost}</td>
											<td style="text-align: left;">
												<ul style="margin-left: 15px; padding-left: 0;">
													{vacancy.eligibility.split('\n').map(line => line.trim() ? <li style="margin-bottom: 5px;">{line}</li> : null)}
												</ul>
											</td>
										</tr>
									))}
								</tbody>
							</table>
						)}

						{categoryVacancyDetails && categoryVacancyDetails.length > 0 && (
							<table class="inner-table" style="margin-top: 15px;">
								<thead>
									<tr>
										<th>Post Name</th>
										<th>UR</th>
										<th>EWS</th>
										<th>OBC</th>
										<th>SC</th>
										<th>ST</th>
										<th>Total</th>
									</tr>
								</thead>
								<tbody>
									{categoryVacancyDetails.map(vacancy => (
										<tr>
											<td>{vacancy.postName}</td>
											<td>{vacancy.ur}</td>
											<td>{vacancy.ews}</td>
											<td>{vacancy.obc}</td>
											<td>{vacancy.sc}</td>
											<td>{vacancy.st}</td>
											<td>{vacancy.total}</td>
										</tr>
									))}
								</tbody>
							</table>
						)}

						{physicalEligibility && physicalEligibility.length > 0 && (
							<table class="inner-table" style="margin-top: 15px;">
								<thead>
									<tr>
										<th>Gender / Category</th>
										<th>Height</th>
										<th>Chest</th>
										<th>Running</th>
									</tr>
								</thead>
								<tbody>
									{physicalEligibility.map(physical => (
										<tr>
											<td>{physical.genderCategory}</td>
											<td>{physical.height}</td>
											<td>{physical.chest}</td>
											<td>{physical.running}</td>
										</tr>
									))}
								</tbody>
							</table>
						)}
					</td>
				</tr>
			)}

			<!-- SECTION 4.5: DISTRICT VACANCY DETAILS -->
			{(districtVacancyTitle || (districtVacancyDetails && districtVacancyDetails.length > 0)) && (
				<tr>
					<td colspan={2} style="padding: 15px;">
						{districtVacancyDetails && districtVacancyDetails.length > 0 && (
							<table class="inner-table" style="margin-top: 15px;">
								<thead>
									{districtVacancyTitle && (
										<tr>
											<th colspan={4} style="background-color: #000033; color: white; padding: 12px; font-size: 20px;">
												{districtVacancyTitle}
											</th>
										</tr>
									)}
									<tr>
										<th>District Name</th>
										<th>No. Of Post</th>
										<th>Last Date</th>
										<th>Notification</th>
									</tr>
								</thead>
								<tbody>
									{districtVacancyDetails.map((district, index) => (
										<tr>
											<!-- Alternate Colors like Sarkari Result -->
											<td style={index === 0 ? "color: #000; font-weight: bold;" : "color: #ff0000; font-weight: bold;"}>{district.districtName}</td>
											<td style={index === 0 ? "color: #000; font-weight: bold;" : "color: #ff0000; font-weight: bold;"}>{district.noOfPost}</td>
											<td style={index === 0 ? "color: #000; font-weight: bold;" : "color: #ff0000; font-weight: bold;"}>{district.lastDate}</td>
											<td style="font-weight: bold;">
												{district.notificationLink ? <a href={district.notificationLink} target="_blank" style="color: #0000ff; text-decoration: none;">Click Here</a> : 'Coming Soon'}
											</td>
										</tr>
									))}
								</tbody>
							</table>
						)}
					</td>
				</tr>
			)}

			<!-- SECTION 5: HOW TO FILL -->
			{(howToFillTitle || howToFillDetails) && (
				<tr>
					<td colspan={2} style="padding: 15px;">
						{howToFillTitle && <h2 style="text-align: center; font-size: 24px; margin-bottom: 15px; color: #008000; margin-top: 0;">{howToFillTitle}</h2>}
						<ul style="margin-left: 20px;">
							{howToFillDetails && howToFillDetails.split('\n').map(item => item.trim() ? <li style="font-size: 18px; margin-bottom: 8px;">{item}</li> : null)}
						</ul>
					</td>
				</tr>
			)}

			<!-- SECTION 6: MARKDOWN CONTENT -->
			<tr>
				<td colspan={2} style="padding: 15px;">
					<h2 style="text-align: center; font-size: 20px; margin-bottom: 15px; color: #ff00ff; margin-top: 0;">Interested Candidates Can Read the Full Notification Before Apply Online</h2>
					<div class="markdown-content">
						<Content />
					</div>
				</td>
			</tr>

			<!-- SECTION 7: IMPORTANT LINKS -->
			{importantLinks && importantLinks.length > 0 && (
				<tr>
					<td colspan={2} style="padding: 0;">
						<h2 style="text-align: center; color: #008000; font-size: 24px; padding: 15px; border-bottom: 1px solid #000; margin: 0;">Some Useful Important Links</h2>
						<table class="inner-table-links" style="width: 100%; border-collapse: collapse;">
							<tbody>
								{importantLinks.map((link, index) => (
									<tr>
										<td style={`width: 50%; text-align: center; padding: 15px; border-right: 1px solid #000; color: #ff00ff; font-size: 20px; font-weight: bold; ${index !== importantLinks.length - 1 ? 'border-bottom: 1px solid #000;' : ''}`}>{link.linkName}</td>
										<td style={`width: 50%; text-align: center; padding: 15px; font-size: 20px; font-weight: bold; ${index !== importantLinks.length - 1 ? 'border-bottom: 1px solid #000;' : ''}`}>
											{link.url ? <a href={link.url} target="_blank" style="color: #0000ff; text-decoration: none;">Click Here</a> : 'Link Available Soon'}
										</td>
									</tr>
								))}
							</tbody>
						</table>
					</td>
				</tr>
			)}

			<!-- SECTION 8: FAQ -->
			{displayFaq && displayFaq.length > 0 && (
				<tr>
					<td colspan={2} style="padding: 0;">
						<h2 style="text-align: center; background-color: #800000; color: #ffffff; font-size: 20px; padding: 10px; border-bottom: 1px solid #000; margin: 0;">Frequently Asked Questions</h2>
						<div style="padding: 15px;">
							{displayFaq.map((item, index) => (
								<div style="margin-bottom: 20px;">
									<div style="color: #ff00ff; font-size: 18px; font-weight: bold; margin-bottom: 8px;">{index + 1}. {item.question}</div>
									<div style="color: #000000; font-size: 16px; margin-left: 10px; line-height: 1.5;">
										<ul>
											{item.answer.split('\n').map(ans => ans.trim() ? <li>{ans}</li> : null)}
										</ul>
									</div>
								</div>
							))}
						</div>
					</td>
				</tr>
			)}
		</table>

	</article>
</Layout>

<style is:global>
	.job-detail-container {
		max-width: 1000px;
		margin: 0 auto;
		background-color: var(--box-bg);
		padding: 20px;
		margin-top: 20px;
	}

	/* Post Header Box (SEO text above table) */
	.post-header-box {
		margin-bottom: 20px;
	}
	.post-header-box .label {
		color: #ff0000;
		font-weight: bold;
	}
	.post-title {
		font-size: 24px;
		color: #000000;
		margin-bottom: 10px;
		line-height: 1.3;
	}
	.post-date, .post-info {
		font-size: 16px;
		margin-bottom: 10px;
		line-height: 1.5;
	}

	/* SARKARI RESULT MASTER TABLE */
	.sarkari-master-table {
		width: 100%;
		border-collapse: collapse;
		border: 1px solid #000000;
		font-family: Arial, Helvetica, sans-serif;
		background-color: #ffffff;
	}
	
	.sarkari-master-table > tbody > tr > td {
		border: 1px solid #000000;
	}

	/* Inner Tables (Vacancy, Physical) */
	.inner-table {
		width: 100%;
		border-collapse: collapse;
	}
	.inner-table th, .inner-table td {
		border: 1px solid #000000;
		padding: 10px;
		text-align: center;
		font-size: 16px;
		font-weight: bold;
	}
	.inner-table th {
		background-color: #f2f2f2;
	}
	
	/* Lists inside tables */
	.sarkari-master-table ul {
		list-style-type: disc;
	}
	.sarkari-master-table li {
		line-height: 1.4;
	}

	/* Markdown Content */
	.markdown-content {
		font-family: Arial, Helvetica, sans-serif;
	}
	.markdown-content a {
		color: #0000ff;
		text-decoration: none;
	}
	.markdown-content a:hover {
		color: #ff0000;
		text-decoration: underline;
	}
	
	/* Highlight Tool (When user clicks </> Code button) */
	.markdown-content code {
		color: #ff0000;
		background-color: #ffffcc;
		font-weight: bold;
		padding: 2px 5px;
		border-radius: 3px;
	}
	
	.markdown-content mark {
		background-color: #ffff00;
		color: #ff0000;
		font-weight: bold;
	}

	/* Hover effects for important links */
	.inner-table-links a:hover {
		color: #ff0000 !important;
		text-decoration: underline !important;
	}
</style>
