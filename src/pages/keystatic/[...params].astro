---
import { makePage } from '@keystatic/astro/ui';
import keystaticConfig from '../../../keystatic.config';

export const prerender = false;
const Keystatic = makePage(keystaticConfig);
---

<div class="keystatic-admin-wrapper">
  <Keystatic />
  
  <!-- Custom Scraper Control Widget -->
  <div class="custom-scraper-control">
    <button id="run-scraper-btn" class="scraper-btn" title="Scrape latest 3 jobs from RSS Feed">
      <span class="btn-icon">⚡</span>
      <span id="scraper-btn-text">Scrape RSS Jobs</span>
      <div id="scraper-spinner" class="spinner hidden"></div>
    </button>
  </div>

  <!-- Toast Container -->
  <div id="toast-container"></div>
</div>

<style>
  .keystatic-admin-wrapper {
    position: relative;
    width: 100%;
    height: 100%;
  }

  /* Floating Scraper Control widget at the bottom-left corner */
  .custom-scraper-control {
    position: fixed;
    bottom: 20px;
    left: 20px;
    z-index: 999999; /* Ensure it stays above Keystatic elements */
  }

  .scraper-btn {
    display: flex;
    align-items: center;
    gap: 8px;
    background: linear-gradient(135deg, #8B0000, #b22222);
    color: #ffffff;
    border: 1px solid rgba(255, 255, 255, 0.2);
    padding: 10px 16px;
    border-radius: 30px;
    font-family: system-ui, -apple-system, sans-serif;
    font-weight: 600;
    font-size: 13.5px;
    cursor: pointer;
    box-shadow: 0 4px 15px rgba(139, 0, 0, 0.35);
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .scraper-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(139, 0, 0, 0.5);
    background: linear-gradient(135deg, #a00000, #c82828);
  }

  .scraper-btn:active {
    transform: translateY(0);
  }

  .scraper-btn:disabled {
    opacity: 0.8;
    cursor: not-allowed;
    transform: none;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2);
  }

  .btn-icon {
    font-size: 15px;
  }

  /* Spinner Animation */
  .spinner {
    width: 14px;
    height: 14px;
    border: 2.5px solid rgba(255, 255, 255, 0.3);
    border-radius: 50%;
    border-top-color: #ffffff;
    animation: spin 1s linear infinite;
  }

  .spinner.hidden {
    display: none;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  /* Toast Container & Notification Styles */
  #toast-container {
    position: fixed;
    top: 20px;
    right: 20px;
    z-index: 1000000;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  :global(.toast) {
    display: flex;
    align-items: center;
    gap: 12px;
    background: #ffffff;
    border-left: 5px solid #16a34a; /* Green success */
    padding: 14px 20px;
    border-radius: 8px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
    font-family: system-ui, -apple-system, sans-serif;
    font-weight: 600;
    font-size: 14px;
    color: #1f2937;
    min-width: 320px;
    max-width: 480px;
    opacity: 0;
    transform: translateY(-20px) scale(0.95);
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  :global(.toast.toast-error) {
    border-left-color: #dc2626; /* Red error */
  }

  :global(.toast.show) {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  :global(.toast.hide) {
    opacity: 0;
    transform: translateY(-10px) scale(0.9);
  }

  :global(.toast-icon) {
    font-size: 18px;
  }

  :global(.toast-message) {
    line-height: 1.4;
  }

  /* Hide widget if screen is tiny */
  @media (max-width: 480px) {
    .custom-scraper-control {
      bottom: 10px;
      left: 10px;
    }
    .scraper-btn {
      padding: 8px 12px;
      font-size: 12px;
    }
  }
</style>

<script>
  function showToast(message: string, type: 'success' | 'error' = 'success') {
    const container = document.getElementById('toast-container');
    if (!container) return;

    const toast = document.createElement('div');
    toast.className = `toast toast-${type}`;
    
    const icon = type === 'success' ? '✅' : '❌';
    toast.innerHTML = `
      <span class="toast-icon">${icon}</span>
      <span class="toast-message">${message}</span>
    `;
    
    container.appendChild(toast);
    
    // Trigger transition Reflow
    toast.offsetHeight;
    toast.classList.add('show');
    
    // Auto remove after 5 seconds
    setTimeout(() => {
      toast.classList.remove('show');
      toast.classList.add('hide');
      setTimeout(() => toast.remove(), 400);
    }, 5000);
  }

  document.addEventListener('DOMContentLoaded', () => {
    const scrapeBtn = document.getElementById('run-scraper-btn');
    const spinner = document.getElementById('scraper-spinner');
    const btnText = document.getElementById('scraper-btn-text');

    if (scrapeBtn) {
      scrapeBtn.addEventListener('click', async () => {
        // Disable button & show spinner
        scrapeBtn.setAttribute('disabled', 'true');
        if (spinner) spinner.classList.remove('hidden');
        if (btnText) btnText.textContent = 'Scraping RSS Feed...';

        try {
          const response = await fetch('/api/scrape', { method: 'POST' });
          const data = await response.json();
          
          if (response.ok && data.success) {
            showToast(data.message, 'success');
            // Wait briefly and then refresh the page so Keystatic shows the newly scraped files!
            setTimeout(() => {
              window.location.reload();
            }, 3000);
          } else {
            showToast(data.message || 'Scraper failed to complete.', 'error');
          }
        } catch (err) {
          showToast('Failed to trigger scraper API. Please check your network connection.', 'error');
        } finally {
          scrapeBtn.removeAttribute('disabled');
          if (spinner) spinner.classList.add('hidden');
          if (btnText) btnText.textContent = 'Scrape RSS Jobs';
        }
      });
    }
  });
</script>
