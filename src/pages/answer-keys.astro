---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const jobs = await getCollection('jobs');
const currentDate = new Date().setHours(0, 0, 0, 0);
const validJobs = jobs.filter(job => {
	if (job.slug.includes('sarkariresult.com') || job.slug.includes('terms-and-conditions')) return false;
	if (!job.data.expiryDate) return true;
	const expiryDate = new Date(job.data.expiryDate).setHours(0, 0, 0, 0);
	return currentDate <= expiryDate;
});

const categoryJobs = validJobs
	.filter(job => job.data.category === 'answer-key')
	.sort((a, b) => new Date(b.data.postDate || new Date()).valueOf() - new Date(a.data.postDate || new Date()).valueOf());
---
<Layout title="Answer Keys | Sarkari Result" description="View all Answer Keys on Sarkari Result." keywords="answer keys, sarkari result">
	<div class="archive-container">
		<div class="box">
			<div class="box-header">All Answer Keys</div>
			<ul class="box-list">
				{categoryJobs.length > 0 ? categoryJobs.map(job => (
					<li><a href={`/jobs/${job.slug}`}>{job.data.title}</a></li>
				)) : <li><a href="#">No Answer Keys Found</a></li>}
			</ul>
		</div>
	</div>
</Layout>
<style>
	.archive-container { max-width: 1000px; margin: 20px auto; }
	.box { background-color: #ffffff; border: 2px solid #8B0000; }
	.box-header { background-color: #8B0000; color: white; font-family: 'Poppins', sans-serif; font-size: 24px; font-weight: bold; text-align: center; padding: 8px 10px; }
	.box-list { list-style-type: disc; padding: 20px 20px 20px 40px; margin: 0; }
	.box-list li { margin-bottom: 15px; line-height: 1.35; }
	.box-list li a { color: #0000ff; text-decoration: underline; font-size: 18px; }
	.box-list li a:hover { color: #ff0000; }
</style>
